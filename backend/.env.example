# Q-Guardian Backend Configuration

# Environment
APP_ENV=development
ENABLE_API_DOCS=true

# JWT Configuration
SECRET_KEY=replace-with-a-unique-32-plus-character-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Admin Credentials
ADMIN_USERNAME=qguardian_admin
ADMIN_PASSWORD_HASH=replace-with-a-bcrypt-hash

# Database Configuration
DATABASE_URL=sqlite:///./qguardian.db

# CORS
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://pnb-q-guardian.vercel.app
# Optional: allow Vercel preview deployments too
# FRONTEND_ORIGIN_REGEX=https://.*\.vercel\.app
